# Frontend (optional — defaults to /api/waitlist via Vite proxy in dev)
# VITE_WAITLIST_URL=https://api.kalpanik.in/api/waitlist

# API server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=kalpanik
DB_PASSWORD=your_db_password
DB_NAME=kalpanik

# SMTP (use your existing mail provider credentials)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=kalpanik432@gmail.com
SMTP_PASS=your_smtp_password
SMTP_FROM=kalpanik432@gmail.com
MAIL_FROM_NAME=Kalpanik
MAIL_REPLY_TO=kalpanik432@gmail.com
# Email that receives a notification when someone joins the waitlist
ADMIN_NOTIFY_EMAIL=kalpanik432@gmail.com

# Founder dashboard login (server-side only — never expose in frontend)
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASSWORD=your_secure_password
JWT_SECRET=generate_a_long_random_secret_here
JWT_EXPIRES_IN=24h
